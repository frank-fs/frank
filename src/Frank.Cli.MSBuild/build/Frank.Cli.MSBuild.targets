<Project>
  <!-- Resolve task assembly path: NuGet package layout (tasks/netstandard2.0/) takes precedence;
       fall back to build output for projects importing from source tree (dev workflow). -->
  <PropertyGroup>
    <_FrankMSBuildTaskAssembly Condition="'$(_FrankMSBuildTaskAssembly)' == '' AND Exists('$(MSBuildThisFileDirectory)../tasks/netstandard2.0/Frank.Cli.MSBuild.dll')">$(MSBuildThisFileDirectory)../tasks/netstandard2.0/Frank.Cli.MSBuild.dll</_FrankMSBuildTaskAssembly>
    <_FrankMSBuildTaskAssembly Condition="'$(_FrankMSBuildTaskAssembly)' == '' AND Exists('$(MSBuildThisFileDirectory)../bin/Debug/netstandard2.0/Frank.Cli.MSBuild.dll')">$(MSBuildThisFileDirectory)../bin/Debug/netstandard2.0/Frank.Cli.MSBuild.dll</_FrankMSBuildTaskAssembly>
    <_FrankMSBuildTaskAssembly Condition="'$(_FrankMSBuildTaskAssembly)' == '' AND Exists('$(MSBuildThisFileDirectory)../bin/Release/netstandard2.0/Frank.Cli.MSBuild.dll')">$(MSBuildThisFileDirectory)../bin/Release/netstandard2.0/Frank.Cli.MSBuild.dll</_FrankMSBuildTaskAssembly>
  </PropertyGroup>

  <UsingTask Condition="'$(_FrankMSBuildTaskAssembly)' != ''"
             TaskName="Frank.Cli.MSBuild.WriteResolvedOptionsJson"
             AssemblyFile="$(_FrankMSBuildTaskAssembly)" />

  <!-- ================================================================
       Resource model binary (produced by frank extract)
       ================================================================
       Static item group: evaluated at project load time, before the F#
       SDK collects resources. A dynamic Target with
       BeforeTargets="CoreCompile" fires too late — the F# compiler
       never sees the resource. -->
  <ItemGroup Condition="Exists('$(FrankResourcesPath)')">
    <EmbeddedResource Include="$(FrankResourcesPath)"
                      LogicalName="$(FrankResourcesLogicalName)"
                      Link="frank/model.bin" />
  </ItemGroup>

  <Target Name="WarnMissingFrankResources"
          BeforeTargets="CoreCompile"
          Condition="!Exists('$(FrankResourcesPath)')">
    <Message Importance="normal"
             Text="Frank: No unified resource model binary found at '$(FrankResourcesPath)'. Run 'frank extract --project $(MSBuildProjectFullPath)' to generate it." />
  </Target>

  <!-- ================================================================
       Semantic definitions (produced by frank compile)
       ================================================================ -->

  <!-- Write MSBuild-resolved project options to a JSON file so that
       frank compile can bypass redundant subprocess MSBuild invocations.
       Incremental: skipped if output JSON is newer than all @(Compile) inputs. -->
  <Target Name="WriteFrankResolvedOptions"
          AfterTargets="ResolveAssemblyReferences"
          BeforeTargets="GenerateFrankSemanticDefinitions"
          Inputs="@(Compile);@(ReferencePath)"
          Outputs="$(FrankCliOutputPath)$(_FrankResolvedOptionsFile)"
          Condition="'$(FrankCliSkipGeneration)' != 'true' AND '$(DesignTimeBuild)' != 'true' AND '$(_FrankMSBuildTaskAssembly)' != ''">
    <WriteResolvedOptionsJson
        OutputPath="$(FrankCliOutputPath)$(_FrankResolvedOptionsFile)"
        SourceFiles="@(Compile)"
        ReferencePaths="@(ReferencePath)"
        DefineConstants="$(DefineConstants)"
        OtherFlags="$(OtherFlags)" />
  </Target>

  <!-- Auto-invoke frank compile before CoreCompile.
       Runs after WriteFrankResolvedOptions so resolved options are ready.
       Incremental: skipped if shapes.shacl.ttl is newer than all @(Compile) inputs. -->
  <Target Name="GenerateFrankSemanticDefinitions"
          DependsOnTargets="WriteFrankResolvedOptions"
          BeforeTargets="CoreCompile"
          Inputs="@(Compile);@(ReferencePath)"
          Outputs="$(FrankCliOutputPath)shapes.shacl.ttl"
          Condition="'$(FrankCliSkipGeneration)' != 'true' AND '$(DesignTimeBuild)' != 'true'">
    <Exec Command="dotnet frank compile --project &quot;$(MSBuildProjectFullPath)&quot; --base-uri &quot;$(FrankCliBaseUri)&quot; --output &quot;$(FrankCliOutputPath)&quot; --project-options-file &quot;$(FrankCliOutputPath)$(_FrankResolvedOptionsFile)&quot;"
          IgnoreExitCode="true"
          ConsoleToMSBuild="true">
      <Output TaskParameter="ExitCode" PropertyName="_FrankCliExitCode" />
    </Exec>
    <Warning Condition="'$(_FrankCliExitCode)' != '0'"
             Text="Frank CLI shape generation failed (exit code $(_FrankCliExitCode)). Shapes may be stale. Run 'dotnet tool restore' if frank is not installed." />
  </Target>

  <!-- Static item group for semantic definitions.
       F# SDK collects EmbeddedResource items before CoreCompile, so dynamic
       Target-based ItemGroups fire too late. Files must exist from a prior
       build or explicit frank compile invocation. On a clean first build,
       GenerateFrankSemanticDefinitions creates the files, but the F# compiler
       won't embed them until the next build when the Exists() conditions pass
       at evaluation time. This is the standard F# limitation for generated
       resources — the same pattern is used for the resource model binary above. -->
  <ItemGroup Condition="Exists('$(FrankCliOutputPath)ontology.owl.xml') AND Exists('$(FrankCliOutputPath)shapes.shacl.ttl') AND Exists('$(FrankCliOutputPath)manifest.json')">
    <EmbeddedResource Include="$(FrankCliOutputPath)ontology.owl.xml"
                      LogicalName="Frank.Semantic.ontology.owl.xml" />
    <EmbeddedResource Include="$(FrankCliOutputPath)shapes.shacl.ttl"
                      LogicalName="Frank.Semantic.shapes.shacl.ttl" />
    <EmbeddedResource Include="$(FrankCliOutputPath)manifest.json"
                      LogicalName="Frank.Semantic.manifest.json" />
  </ItemGroup>

  <Target Name="ValidateFrankSemanticDefinitions"
          BeforeTargets="Build"
          Condition="!Exists('$(FrankCliOutputPath)manifest.json')">
    <Warning Text="Frank.Cli.MSBuild is referenced but no semantic definitions found in '$(FrankCliOutputPath)'. Run 'frank compile' to generate them." />
  </Target>
</Project>
