<Project>

  <!--
    Assembly resolution: when imported directly (not via NuGet pack), the dll
    lives at bin/<Configuration>/net8.0/ relative to the .targets file's parent.
    When imported from a NuGet pack the dll lives at lib/net8.0/ in the pack
    layout. The property FrankMSBuildAssemblyFile can be set by the caller to
    override both defaults.
  -->
  <PropertyGroup>
    <FrankMSBuildAssemblyFile Condition="'$(FrankMSBuildAssemblyFile)' == '' and Exists('$(MSBuildThisFileDirectory)..\lib\net8.0\Frank.Cli.MSBuild.dll')">$(MSBuildThisFileDirectory)..\lib\net8.0\Frank.Cli.MSBuild.dll</FrankMSBuildAssemblyFile>
    <FrankMSBuildAssemblyFile Condition="'$(FrankMSBuildAssemblyFile)' == ''">$(MSBuildThisFileDirectory)..\bin\$(Configuration)\net8.0\Frank.Cli.MSBuild.dll</FrankMSBuildAssemblyFile>
  </PropertyGroup>

  <UsingTask
    TaskName="Frank.Cli.MSBuild.ValidateLockFileTask"
    AssemblyFile="$(FrankMSBuildAssemblyFile)" />

  <UsingTask
    TaskName="Frank.Cli.MSBuild.GenerateDiscoveryTask"
    AssemblyFile="$(FrankMSBuildAssemblyFile)" />

  <UsingTask
    TaskName="Frank.Cli.MSBuild.GenerateLinkedDataTask"
    AssemblyFile="$(FrankMSBuildAssemblyFile)" />

  <UsingTask
    TaskName="Frank.Cli.MSBuild.GenerateSemanticsTask"
    AssemblyFile="$(FrankMSBuildAssemblyFile)" />

  <UsingTask
    TaskName="Frank.Cli.MSBuild.GenerateValidationTask"
    AssemblyFile="$(FrankMSBuildAssemblyFile)" />

  <!--
    FrankGenerateSemantic: validate lock file and generate GeneratedDiscovery.fs.
    Incremental: skipped when lock file is unchanged and output already exists.
    Always validates (gate); generates only when Frank.Discovery is referenced.
  -->
  <Target Name="FrankGenerateSemantic"
          BeforeTargets="FrankInjectGeneratedFile"
          Inputs="$(FrankLockFilePath)"
          Outputs="$(IntermediateOutputPath)GeneratedDiscovery.fs"
          Condition="Exists('$(FrankLockFilePath)')">

    <!-- Late-bind SDK-computed properties inside the target.
         IntermediateOutputPath is not set at .props import time. -->
    <PropertyGroup>
      <FrankLockFilePath Condition="'$(FrankLockFilePath)' == ''">$(MSBuildProjectDirectory)/.frank/semantic-mappings.lock.json</FrankLockFilePath>
      <FrankDiscoveryModuleName Condition="'$(FrankDiscoveryModuleName)' == ''">$(RootNamespace).GeneratedDiscovery</FrankDiscoveryModuleName>
      <FrankProfileUri Condition="'$(FrankProfileUri)' == ''">/alps/$(MSBuildProjectName.ToLower())</FrankProfileUri>
    </PropertyGroup>

    <!-- Step 1: validate the lock file (always). Build fails here if any mapping is non-Confirmed. -->
    <ValidateLockFileTask LockFilePath="$(FrankLockFilePath)" />

    <!-- Step 2: detect Frank.Discovery reference (package or project). -->
    <PropertyGroup>
      <_FrankHasDiscovery Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Frank.Discovery')) == 'True'">true</_FrankHasDiscovery>
      <_FrankHasDiscovery Condition="@(ProjectReference->AnyHaveMetadataValue('Filename', 'Frank.Discovery')) == 'True'">true</_FrankHasDiscovery>
    </PropertyGroup>

    <!-- Step 3: generate the F# module. -->
    <GenerateDiscoveryTask
      Condition="'$(_FrankHasDiscovery)' == 'true'"
      LockFilePath="$(FrankLockFilePath)"
      OutputPath="$(IntermediateOutputPath)"
      ModuleName="$(FrankDiscoveryModuleName)"
      ProfileUri="$(FrankProfileUri)">
      <Output TaskParameter="GeneratedFile" PropertyName="_FrankGeneratedDiscoveryFile" />
    </GenerateDiscoveryTask>

    <ItemGroup Condition="'$(_FrankHasDiscovery)' == 'true' and '$(_FrankGeneratedDiscoveryFile)' != ''">
      <FileWrites Include="$(_FrankGeneratedDiscoveryFile)" />
    </ItemGroup>

  </Target>

  <!--
    FrankInjectGeneratedFile: always runs before CoreCompile (not incremental).
    Injects the already-generated GeneratedDiscovery.fs into @(Compile).

    Ordering strategy (explicit-item-first, best-effort default):
    - If the project already lists the generated file in @(Compile), skip — the
      author controls position.
    - Else if Program.fs is in @(Compile), insert immediately before it.
    - Else insert before the last @(Compile) item (best-effort: at minimum the
      generated file precedes the final consumer).
    Limitation: "before the resource-definition file" is impractical in pure
    MSBuild without a file-content probe; Program.fs-or-last is the defensible
    default for library projects that omit Program.fs.
  -->
  <Target Name="FrankInjectGeneratedFile"
          BeforeTargets="BeforeCompile;CoreCompile"
          Condition="Exists('$(IntermediateOutputPath)GeneratedDiscovery.fs')">

    <PropertyGroup>
      <_FrankGeneratedFile>$(IntermediateOutputPath)GeneratedDiscovery.fs</_FrankGeneratedFile>
    </PropertyGroup>

    <!-- Step 1: capture anchor candidates (before any reordering). -->
    <ItemGroup Condition="!@(Compile->AnyHaveMetadataValue('Identity', '$(_FrankGeneratedFile)'))">
      <!-- Case A anchor: Program.fs if present. -->
      <_FrankProgramFs Include="@(Compile)" Condition="'%(Filename)%(Extension)' == 'Program.fs'" />
      <!-- Case B anchor: last compile item (used only when Program.fs absent). -->
      <_FrankLastCompile Include="@(Compile->Reverse()->First())" Condition="'@(_FrankProgramFs)' == ''" />
    </ItemGroup>

    <!-- Step 2 Case A: Program.fs present — remove it, insert generated file, re-add. -->
    <ItemGroup Condition="!@(Compile->AnyHaveMetadataValue('Identity', '$(_FrankGeneratedFile)')) and '@(_FrankProgramFs)' != ''">
      <Compile Remove="@(_FrankProgramFs)" />
      <Compile Include="$(_FrankGeneratedFile)" />
      <Compile Include="@(_FrankProgramFs)" />
    </ItemGroup>

    <!-- Step 2 Case B: no Program.fs — insert generated file before the last item. -->
    <ItemGroup Condition="!@(Compile->AnyHaveMetadataValue('Identity', '$(_FrankGeneratedFile)')) and '@(_FrankProgramFs)' == '' and '@(_FrankLastCompile)' != ''">
      <Compile Remove="@(_FrankLastCompile)" />
      <Compile Include="$(_FrankGeneratedFile)" />
      <Compile Include="@(_FrankLastCompile)" />
    </ItemGroup>

  </Target>

  <!--
    FrankGenerateLinkedData: evaluate the vocabulary CE in-process via FSI and emit
    GeneratedLinkedData.fs. Only runs when Frank.LinkedData is referenced.

    Incremental: Inputs = lock file + all project compile items (vocab CE source).
                 Outputs = $(IntermediateOutputPath)GeneratedLinkedData.fs.

    Separation of concerns mirrors the Discovery pair:
    - FrankGenerateLinkedData writes the file (incremental, skippable when inputs unchanged).
    - FrankInjectGeneratedLinkedDataFile wires the file into @(Compile) (always).
  -->
  <Target Name="FrankGenerateLinkedData"
          BeforeTargets="FrankInjectGeneratedLinkedDataFile"
          Inputs="$(FrankLockFilePath);@(Compile)"
          Outputs="$(IntermediateOutputPath)GeneratedLinkedData.fs"
          Condition="Exists('$(FrankLockFilePath)') and (@(PackageReference->AnyHaveMetadataValue('Identity', 'Frank.LinkedData')) == 'True' or @(ProjectReference->AnyHaveMetadataValue('Filename', 'Frank.LinkedData')) == 'True')">

    <!-- Late-bind SDK-computed properties inside the target. -->
    <PropertyGroup>
      <FrankLockFilePath Condition="'$(FrankLockFilePath)' == ''">$(MSBuildProjectDirectory)/.frank/semantic-mappings.lock.json</FrankLockFilePath>
      <FrankLinkedDataModuleName Condition="'$(FrankLinkedDataModuleName)' == ''">$(RootNamespace).GeneratedLinkedData</FrankLinkedDataModuleName>
      <FrankVocabularyBinding Condition="'$(FrankVocabularyBinding)' == ''">registry</FrankVocabularyBinding>
    </PropertyGroup>

    <!--
      Source files for the in-process FSI eval = the vocabulary CE's dependency closure.
      Exclude: .fsi (FSI cannot #load a standalone signature file), the entry point
      Program.fs (it references the not-yet-generated modules), and any Generated*.fs.
      An explicit $(FrankVocabularySourceFiles) overrides this default when set.
    -->
    <ItemGroup>
      <_FrankVocabSource Include="$(FrankVocabularySourceFiles)" Condition="'$(FrankVocabularySourceFiles)' != ''" />
      <_FrankVocabSource Include="@(Compile->'%(FullPath)')"
                         Condition="'$(FrankVocabularySourceFiles)' == '' And '%(Extension)' != '.fsi' And '%(Filename)%(Extension)' != 'Program.fs' And !$([System.String]::Copy('%(Filename)').StartsWith('Generated'))" />
    </ItemGroup>

    <GenerateLinkedDataTask
      LockFilePath="$(FrankLockFilePath)"
      OutputPath="$(IntermediateOutputPath)"
      ModuleName="$(FrankLinkedDataModuleName)"
      SourceFiles="@(_FrankVocabSource)"
      AssemblyRefs="@(ReferencePath)"
      VocabularyBinding="$(FrankVocabularyBinding)">
      <Output TaskParameter="GeneratedFile" PropertyName="_FrankGeneratedLinkedDataFile" />
    </GenerateLinkedDataTask>

    <ItemGroup Condition="'$(_FrankGeneratedLinkedDataFile)' != ''">
      <FileWrites Include="$(_FrankGeneratedLinkedDataFile)" />
    </ItemGroup>

  </Target>

  <!--
    FrankInjectGeneratedLinkedDataFile: always runs before CoreCompile (not incremental).
    Injects the already-generated GeneratedLinkedData.fs into @(Compile).

    Same ordering strategy as FrankInjectGeneratedFile: explicit-item-first,
    Program.fs-or-last-item best-effort default.
  -->
  <Target Name="FrankInjectGeneratedLinkedDataFile"
          BeforeTargets="BeforeCompile;CoreCompile"
          Condition="Exists('$(IntermediateOutputPath)GeneratedLinkedData.fs')">

    <PropertyGroup>
      <_FrankGeneratedLDFile>$(IntermediateOutputPath)GeneratedLinkedData.fs</_FrankGeneratedLDFile>
    </PropertyGroup>

    <!-- Step 1: capture anchor candidates. -->
    <ItemGroup Condition="!@(Compile->AnyHaveMetadataValue('Identity', '$(_FrankGeneratedLDFile)'))">
      <_FrankProgramFsLD Include="@(Compile)" Condition="'%(Filename)%(Extension)' == 'Program.fs'" />
      <_FrankLastCompileLD Include="@(Compile->Reverse()->First())" Condition="'@(_FrankProgramFsLD)' == ''" />
    </ItemGroup>

    <!-- Step 2 Case A: Program.fs present. -->
    <ItemGroup Condition="!@(Compile->AnyHaveMetadataValue('Identity', '$(_FrankGeneratedLDFile)')) and '@(_FrankProgramFsLD)' != ''">
      <Compile Remove="@(_FrankProgramFsLD)" />
      <Compile Include="$(_FrankGeneratedLDFile)" />
      <Compile Include="@(_FrankProgramFsLD)" />
    </ItemGroup>

    <!-- Step 2 Case B: no Program.fs — insert before last item. -->
    <ItemGroup Condition="!@(Compile->AnyHaveMetadataValue('Identity', '$(_FrankGeneratedLDFile)')) and '@(_FrankProgramFsLD)' == '' and '@(_FrankLastCompileLD)' != ''">
      <Compile Remove="@(_FrankLastCompileLD)" />
      <Compile Include="$(_FrankGeneratedLDFile)" />
      <Compile Include="@(_FrankLastCompileLD)" />
    </ItemGroup>

  </Target>

  <!--
    FrankGenerateSemanticModel: evaluate the vocabulary CE in-process via FCS and emit
    GeneratedSemantics.fs. Gate: Exists(lock file) only — no package condition, because
    GeneratedSemantics references only domain types + System.Type (no Frank runtime package).

    Incremental: Inputs = lock file + all project compile items (vocab CE source).
                 Outputs = $(IntermediateOutputPath)GeneratedSemantics.fs.

    Separation of concerns mirrors the LinkedData pair:
    - FrankGenerateSemanticModel writes the file (incremental, skippable when inputs unchanged).
    - FrankInjectGeneratedSemanticModelFile wires the file into @(Compile) (always).
  -->
  <Target Name="FrankGenerateSemanticModel"
          BeforeTargets="FrankInjectGeneratedSemanticModelFile"
          Inputs="$(FrankLockFilePath);@(Compile)"
          Outputs="$(IntermediateOutputPath)GeneratedSemantics.fs"
          Condition="Exists('$(FrankLockFilePath)')">

    <!-- Late-bind SDK-computed properties inside the target. -->
    <PropertyGroup>
      <FrankLockFilePath Condition="'$(FrankLockFilePath)' == ''">$(MSBuildProjectDirectory)/.frank/semantic-mappings.lock.json</FrankLockFilePath>
      <FrankSemanticsModuleName Condition="'$(FrankSemanticsModuleName)' == ''">$(RootNamespace).GeneratedSemantics</FrankSemanticsModuleName>
      <FrankVocabularyBinding Condition="'$(FrankVocabularyBinding)' == ''">registry</FrankVocabularyBinding>
    </PropertyGroup>

    <!--
      Source files for the in-process FCS eval = the vocabulary CE's dependency closure.
      Exclude: .fsi (FCS cannot #load a standalone signature file), the entry point
      Program.fs (it references the not-yet-generated modules), and any Generated*.fs.
      An explicit $(FrankVocabularySourceFiles) overrides this default when set.
    -->
    <ItemGroup>
      <_FrankSemVocabSource Include="$(FrankVocabularySourceFiles)" Condition="'$(FrankVocabularySourceFiles)' != ''" />
      <_FrankSemVocabSource Include="@(Compile->'%(FullPath)')"
                            Condition="'$(FrankVocabularySourceFiles)' == '' And '%(Extension)' != '.fsi' And '%(Filename)%(Extension)' != 'Program.fs' And !$([System.String]::Copy('%(Filename)').StartsWith('Generated'))" />
    </ItemGroup>

    <GenerateSemanticsTask
      LockFilePath="$(FrankLockFilePath)"
      OutputPath="$(IntermediateOutputPath)"
      ModuleName="$(FrankSemanticsModuleName)"
      SourceFiles="@(_FrankSemVocabSource)"
      AssemblyRefs="@(ReferencePath)"
      VocabularyBinding="$(FrankVocabularyBinding)">
      <Output TaskParameter="GeneratedFile" PropertyName="_FrankGeneratedSemanticsFile" />
    </GenerateSemanticsTask>

    <ItemGroup Condition="'$(_FrankGeneratedSemanticsFile)' != ''">
      <FileWrites Include="$(_FrankGeneratedSemanticsFile)" />
    </ItemGroup>

  </Target>

  <!--
    FrankInjectGeneratedSemanticModelFile: always runs before CoreCompile (not incremental).
    Injects the already-generated GeneratedSemantics.fs into @(Compile).

    GeneratedSemantics references domain types by fully-qualified name, so it only needs
    to compile after the domain (e.g. Model.fs). Same ordering strategy as the other
    inject targets: explicit-item-first, Program.fs-or-last-item best-effort default.
  -->
  <Target Name="FrankInjectGeneratedSemanticModelFile"
          BeforeTargets="BeforeCompile;CoreCompile"
          Condition="Exists('$(IntermediateOutputPath)GeneratedSemantics.fs')">

    <PropertyGroup>
      <_FrankGeneratedSemFile>$(IntermediateOutputPath)GeneratedSemantics.fs</_FrankGeneratedSemFile>
    </PropertyGroup>

    <!-- Step 1: capture anchor candidates. -->
    <ItemGroup Condition="!@(Compile->AnyHaveMetadataValue('Identity', '$(_FrankGeneratedSemFile)'))">
      <_FrankProgramFsSem Include="@(Compile)" Condition="'%(Filename)%(Extension)' == 'Program.fs'" />
      <_FrankLastCompileSem Include="@(Compile->Reverse()->First())" Condition="'@(_FrankProgramFsSem)' == ''" />
    </ItemGroup>

    <!-- Step 2 Case A: Program.fs present. -->
    <ItemGroup Condition="!@(Compile->AnyHaveMetadataValue('Identity', '$(_FrankGeneratedSemFile)')) and '@(_FrankProgramFsSem)' != ''">
      <Compile Remove="@(_FrankProgramFsSem)" />
      <Compile Include="$(_FrankGeneratedSemFile)" />
      <Compile Include="@(_FrankProgramFsSem)" />
    </ItemGroup>

    <!-- Step 2 Case B: no Program.fs — insert before last item. -->
    <ItemGroup Condition="!@(Compile->AnyHaveMetadataValue('Identity', '$(_FrankGeneratedSemFile)')) and '@(_FrankProgramFsSem)' == '' and '@(_FrankLastCompileSem)' != ''">
      <Compile Remove="@(_FrankLastCompileSem)" />
      <Compile Include="$(_FrankGeneratedSemFile)" />
      <Compile Include="@(_FrankLastCompileSem)" />
    </ItemGroup>

  </Target>

  <!--
    FrankGenerateValidation: evaluate the vocabulary CE in-process via FCS and emit
    GeneratedValidation.fs. Only runs when Frank.Validation is referenced.

    Incremental: Inputs = lock file + all project compile items (vocab CE source).
                 Outputs = $(IntermediateOutputPath)GeneratedValidation.fs.

    Separation of concerns mirrors the LinkedData pair:
    - FrankGenerateValidation writes the file (incremental, skippable when inputs unchanged).
    - FrankInjectGeneratedValidationFile wires the file into @(Compile) (always).
  -->
  <Target Name="FrankGenerateValidation"
          BeforeTargets="FrankInjectGeneratedValidationFile"
          Inputs="$(FrankLockFilePath);@(Compile)"
          Outputs="$(IntermediateOutputPath)GeneratedValidation.fs"
          Condition="Exists('$(FrankLockFilePath)') and (@(PackageReference->AnyHaveMetadataValue('Identity', 'Frank.Validation')) == 'True' or @(ProjectReference->AnyHaveMetadataValue('Filename', 'Frank.Validation')) == 'True')">

    <!-- Late-bind SDK-computed properties inside the target. -->
    <PropertyGroup>
      <FrankLockFilePath Condition="'$(FrankLockFilePath)' == ''">$(MSBuildProjectDirectory)/.frank/semantic-mappings.lock.json</FrankLockFilePath>
      <FrankValidationModuleName Condition="'$(FrankValidationModuleName)' == ''">$(RootNamespace).GeneratedValidation</FrankValidationModuleName>
      <FrankVocabularyBinding Condition="'$(FrankVocabularyBinding)' == ''">registry</FrankVocabularyBinding>
    </PropertyGroup>

    <!--
      Source files for the in-process FCS eval = the vocabulary CE's dependency closure.
      Exclude: .fsi (FCS cannot #load a standalone signature file), the entry point
      Program.fs (it references the not-yet-generated modules), and any Generated*.fs.
      An explicit $(FrankVocabularySourceFiles) overrides this default when set.
    -->
    <ItemGroup>
      <_FrankValVocabSource Include="$(FrankVocabularySourceFiles)" Condition="'$(FrankVocabularySourceFiles)' != ''" />
      <_FrankValVocabSource Include="@(Compile->'%(FullPath)')"
                            Condition="'$(FrankVocabularySourceFiles)' == '' And '%(Extension)' != '.fsi' And '%(Filename)%(Extension)' != 'Program.fs' And !$([System.String]::Copy('%(Filename)').StartsWith('Generated'))" />
    </ItemGroup>

    <GenerateValidationTask
      LockFilePath="$(FrankLockFilePath)"
      OutputPath="$(IntermediateOutputPath)"
      ModuleName="$(FrankValidationModuleName)"
      SourceFiles="@(_FrankValVocabSource)"
      AssemblyRefs="@(ReferencePath)"
      VocabularyBinding="$(FrankVocabularyBinding)">
      <Output TaskParameter="GeneratedFile" PropertyName="_FrankGeneratedValidationFile" />
    </GenerateValidationTask>

    <ItemGroup Condition="'$(_FrankGeneratedValidationFile)' != ''">
      <FileWrites Include="$(_FrankGeneratedValidationFile)" />
    </ItemGroup>

  </Target>

  <!--
    FrankInjectGeneratedValidationFile: always runs before CoreCompile (not incremental).
    Injects the already-generated GeneratedValidation.fs into @(Compile).

    Same ordering strategy as FrankInjectGeneratedLinkedDataFile: explicit-item-first,
    Program.fs-or-last-item best-effort default.
  -->
  <Target Name="FrankInjectGeneratedValidationFile"
          BeforeTargets="BeforeCompile;CoreCompile"
          Condition="Exists('$(IntermediateOutputPath)GeneratedValidation.fs')">

    <PropertyGroup>
      <_FrankGeneratedValFile>$(IntermediateOutputPath)GeneratedValidation.fs</_FrankGeneratedValFile>
    </PropertyGroup>

    <!-- Step 1: capture anchor candidates. -->
    <ItemGroup Condition="!@(Compile->AnyHaveMetadataValue('Identity', '$(_FrankGeneratedValFile)'))">
      <_FrankProgramFsVal Include="@(Compile)" Condition="'%(Filename)%(Extension)' == 'Program.fs'" />
      <_FrankLastCompileVal Include="@(Compile->Reverse()->First())" Condition="'@(_FrankProgramFsVal)' == ''" />
    </ItemGroup>

    <!-- Step 2 Case A: Program.fs present. -->
    <ItemGroup Condition="!@(Compile->AnyHaveMetadataValue('Identity', '$(_FrankGeneratedValFile)')) and '@(_FrankProgramFsVal)' != ''">
      <Compile Remove="@(_FrankProgramFsVal)" />
      <Compile Include="$(_FrankGeneratedValFile)" />
      <Compile Include="@(_FrankProgramFsVal)" />
    </ItemGroup>

    <!-- Step 2 Case B: no Program.fs — insert before last item. -->
    <ItemGroup Condition="!@(Compile->AnyHaveMetadataValue('Identity', '$(_FrankGeneratedValFile)')) and '@(_FrankProgramFsVal)' == '' and '@(_FrankLastCompileVal)' != ''">
      <Compile Remove="@(_FrankLastCompileVal)" />
      <Compile Include="$(_FrankGeneratedValFile)" />
      <Compile Include="@(_FrankLastCompileVal)" />
    </ItemGroup>

  </Target>

</Project>
