<Project>
  <!-- T061: Auto-invoke frank-cli compile --project before CoreCompile.
       Runs after ResolveAssemblyReferences so the project's assembly list is stable.
       Incremental: skipped if shapes.shacl.ttl is newer than all @(Compile) inputs (T062). -->
  <Target Name="GenerateFrankSemanticDefinitions"
          AfterTargets="ResolveAssemblyReferences"
          BeforeTargets="CoreCompile"
          Inputs="@(Compile)"
          Outputs="$(FrankCliOutputPath)shapes.shacl.ttl"
          Condition="'$(FrankCliSkipGeneration)' != 'true'">
    <Exec Command="dotnet frank-cli compile --project &quot;$(MSBuildProjectFullPath)&quot; --base-uri &quot;$(FrankCliBaseUri)&quot; --output &quot;$(FrankCliOutputPath)&quot;"
          IgnoreExitCode="true"
          ConsoleToMSBuild="true">
      <Output TaskParameter="ExitCode" PropertyName="_FrankCliExitCode" />
    </Exec>
    <Warning Condition="'$(_FrankCliExitCode)' != '0'"
             Text="Frank CLI shape generation failed (exit code $(_FrankCliExitCode)). Shapes may be stale. Run 'dotnet tool restore' if frank-cli is not installed." />
  </Target>

  <Target Name="EmbedFrankSemanticDefinitions"
          AfterTargets="GenerateFrankSemanticDefinitions"
          BeforeTargets="CoreCompile"
          Condition="Exists('$(FrankCliOutputPath)ontology.owl.xml') AND Exists('$(FrankCliOutputPath)shapes.shacl.ttl') AND Exists('$(FrankCliOutputPath)manifest.json')">
    <ItemGroup>
      <EmbeddedResource Include="$(FrankCliOutputPath)ontology.owl.xml"
                        LogicalName="Frank.Semantic.ontology.owl.xml" />
      <EmbeddedResource Include="$(FrankCliOutputPath)shapes.shacl.ttl"
                        LogicalName="Frank.Semantic.shapes.shacl.ttl" />
      <EmbeddedResource Include="$(FrankCliOutputPath)manifest.json"
                        LogicalName="Frank.Semantic.manifest.json" />
    </ItemGroup>
  </Target>

  <Target Name="ValidateFrankSemanticDefinitions"
          BeforeTargets="Build"
          Condition="!Exists('$(FrankCliOutputPath)manifest.json')">
    <Warning Text="Frank.Cli.MSBuild is referenced but no semantic definitions found in '$(FrankCliOutputPath)'. Run 'frank-cli compile' to generate them." />
  </Target>
</Project>
