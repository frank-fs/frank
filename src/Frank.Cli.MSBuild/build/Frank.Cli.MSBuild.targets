<Project>
  <!-- ================================================================
       Resource model binary (produced by frank extract)
       ================================================================
       Static item group: evaluated at project load time, before the F#
       SDK collects resources. A dynamic Target with
       BeforeTargets="CoreCompile" fires too late — the F# compiler
       never sees the resource. -->
  <ItemGroup Condition="Exists('$(FrankResourcesPath)')">
    <EmbeddedResource Include="$(FrankResourcesPath)"
                      LogicalName="$(FrankResourcesLogicalName)"
                      Link="frank/model.bin" />
  </ItemGroup>

  <Target Name="WarnMissingFrankResources"
          BeforeTargets="CoreCompile"
          Condition="!Exists('$(FrankResourcesPath)')">
    <Message Importance="normal"
             Text="Frank: No unified resource model binary found at '$(FrankResourcesPath)'. Run 'frank extract --project $(MSBuildProjectFullPath)' to generate it." />
  </Target>

  <!-- ================================================================
       Semantic definitions (produced by frank compile)
       ================================================================ -->

  <!-- Auto-invoke frank compile before CoreCompile.
       Runs after ResolveAssemblyReferences so the project's assembly list is stable.
       Incremental: skipped if shapes.shacl.ttl is newer than all @(Compile) inputs. -->
  <Target Name="GenerateFrankSemanticDefinitions"
          AfterTargets="ResolveAssemblyReferences"
          BeforeTargets="CoreCompile"
          Inputs="@(Compile)"
          Outputs="$(FrankCliOutputPath)shapes.shacl.ttl"
          Condition="'$(FrankCliSkipGeneration)' != 'true'">
    <Exec Command="dotnet frank compile --project &quot;$(MSBuildProjectFullPath)&quot; --base-uri &quot;$(FrankCliBaseUri)&quot; --output &quot;$(FrankCliOutputPath)&quot;"
          IgnoreExitCode="true"
          ConsoleToMSBuild="true">
      <Output TaskParameter="ExitCode" PropertyName="_FrankCliExitCode" />
    </Exec>
    <Warning Condition="'$(_FrankCliExitCode)' != '0'"
             Text="Frank CLI shape generation failed (exit code $(_FrankCliExitCode)). Shapes may be stale. Run 'dotnet tool restore' if frank is not installed." />
  </Target>

  <!-- Static item group for semantic definitions — same rationale as
       unified state above. Files must exist from a prior build or
       explicit frank compile invocation. -->
  <ItemGroup Condition="Exists('$(FrankCliOutputPath)ontology.owl.xml') AND Exists('$(FrankCliOutputPath)shapes.shacl.ttl') AND Exists('$(FrankCliOutputPath)manifest.json')">
    <EmbeddedResource Include="$(FrankCliOutputPath)ontology.owl.xml"
                      LogicalName="Frank.Semantic.ontology.owl.xml" />
    <EmbeddedResource Include="$(FrankCliOutputPath)shapes.shacl.ttl"
                      LogicalName="Frank.Semantic.shapes.shacl.ttl" />
    <EmbeddedResource Include="$(FrankCliOutputPath)manifest.json"
                      LogicalName="Frank.Semantic.manifest.json" />
  </ItemGroup>

  <Target Name="ValidateFrankSemanticDefinitions"
          BeforeTargets="Build"
          Condition="!Exists('$(FrankCliOutputPath)manifest.json')">
    <Warning Text="Frank.Cli.MSBuild is referenced but no semantic definitions found in '$(FrankCliOutputPath)'. Run 'frank compile' to generate them." />
  </Target>
</Project>
