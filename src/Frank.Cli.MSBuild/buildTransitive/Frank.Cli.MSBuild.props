<Project>
  <PropertyGroup>
    <FrankCliOutputPath Condition="'$(FrankCliOutputPath)' == ''">$(IntermediateOutputPath)frank-cli/</FrankCliOutputPath>
    <!-- Set to 'true' to opt out of automatic shape generation during build. -->
    <FrankCliBaseUri Condition="'$(FrankCliBaseUri)' == ''">urn:frank:$(AssemblyName)/</FrankCliBaseUri>
    <FrankCliSkipGeneration Condition="'$(FrankCliSkipGeneration)' == ''">false</FrankCliSkipGeneration>
    <!-- Unified state binary produced by frank-cli extract -->
    <FrankDescriptorsPath Condition="'$(FrankDescriptorsPath)' == ''">$(BaseIntermediateOutputPath)frank-cli/descriptors.bin</FrankDescriptorsPath>
    <FrankDescriptorsLogicalName Condition="'$(FrankDescriptorsLogicalName)' == ''">Frank.Affordances.descriptors.bin</FrankDescriptorsLogicalName>
  </PropertyGroup>
</Project>
