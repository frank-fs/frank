<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net8.0;net9.0;net10.0</TargetFrameworks>
    <PackageTags>provenance;prov-o;w3c;state-change;tracking</PackageTags>
    <Description>W3C PROV-O based provenance tracking for Frank web framework state changes</Description>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="Vocabulary.fs" />
    <Compile Include="Types.fs" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../Frank/Frank.fsproj" />
  </ItemGroup>

</Project>
