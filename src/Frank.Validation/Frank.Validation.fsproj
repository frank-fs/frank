<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net8.0;net9.0;net10.0</TargetFrameworks>
    <PackageTags>validation;shacl;rdf;shapes</PackageTags>
    <Description>SHACL validation interpreter for Frank shape declarations</Description>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="ValidationTypes.fs" />
    <Compile Include="Shapes.fs" />
    <Compile Include="Validator.fs" />
    <Compile Include="JsonLdLoader.fs" />
    <Compile Include="GeneratedValidationResolver.fs" />
    <Compile Include="ValidationMiddleware.fs" />
    <Compile Include="Frank.Validation.fs" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../Frank/Frank.fsproj" />
    <ProjectReference Include="../Frank.Semantic/Frank.Semantic.fsproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="dotNetRdf.Core" Version="3.5.1" />
    <PackageReference Include="dotNetRdf.Shacl" Version="3.5.1" />
  </ItemGroup>

</Project>
