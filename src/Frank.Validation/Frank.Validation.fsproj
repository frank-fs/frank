<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net8.0;net9.0;net10.0</TargetFrameworks>
    <Description>SHACL validation middleware for Frank — consumes GeneratedValidation artifacts</Description>
    <PackageTags>shacl;validation;rdf;semantic;hypermedia</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="ValidationReport.fs" />
    <Compile Include="ValidationMiddleware.fs" />
    <Compile Include="Frank.Validation.fs" />
  </ItemGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="dotNetRDF.Core" Version="3.5.1" />
    <PackageReference Include="dotNetRDF.Shacl" Version="3.5.1" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../Frank/Frank.fsproj" />
  </ItemGroup>

</Project>
