<Project>
  <!-- Properties: paths to artifacts produced by frank-cli -->
  <PropertyGroup>
    <FrankUnifiedStatePath Condition="'$(FrankUnifiedStatePath)' == ''">$(BaseIntermediateOutputPath)frank-cli/unified-state.bin</FrankUnifiedStatePath>
    <FrankUnifiedStateLogicalName Condition="'$(FrankUnifiedStateLogicalName)' == ''">Frank.Affordances.unified-state.bin</FrankUnifiedStateLogicalName>
    <FrankRuntimeStatePath Condition="'$(FrankRuntimeStatePath)' == ''">$(BaseIntermediateOutputPath)frank-cli/runtime-state.json</FrankRuntimeStatePath>
    <FrankRuntimeStateLogicalName Condition="'$(FrankRuntimeStateLogicalName)' == ''">Frank.Affordances.runtime-state.json</FrankRuntimeStateLogicalName>
  </PropertyGroup>

  <!-- Target: embed the unified state binary if it exists -->
  <Target Name="EmbedFrankUnifiedState"
          BeforeTargets="CoreCompile"
          Condition="Exists('$(FrankUnifiedStatePath)')">
    <Message Importance="normal"
             Text="Frank: Embedding unified state from '$(FrankUnifiedStatePath)' as '$(FrankUnifiedStateLogicalName)'" />
    <ItemGroup>
      <EmbeddedResource Include="$(FrankUnifiedStatePath)"
                        LogicalName="$(FrankUnifiedStateLogicalName)"
                        Link="frank-cli/unified-state.bin" />
    </ItemGroup>
  </Target>

  <!-- Target: embed the runtime state if it exists (produced by frank-cli compile) -->
  <Target Name="EmbedFrankRuntimeState"
          BeforeTargets="CoreCompile"
          Condition="Exists('$(FrankRuntimeStatePath)')">
    <Message Importance="normal"
             Text="Frank: Embedding runtime state from '$(FrankRuntimeStatePath)' as '$(FrankRuntimeStateLogicalName)'" />
    <ItemGroup>
      <EmbeddedResource Include="$(FrankRuntimeStatePath)"
                        LogicalName="$(FrankRuntimeStateLogicalName)"
                        Link="frank-cli/runtime-state.json" />
    </ItemGroup>
  </Target>

  <!-- Target: informational message if neither artifact exists -->
  <Target Name="WarnMissingFrankState"
          BeforeTargets="CoreCompile"
          Condition="!Exists('$(FrankUnifiedStatePath)') AND !Exists('$(FrankRuntimeStatePath)')">
    <Message Importance="normal"
             Text="Frank: No unified state found at '$(FrankUnifiedStatePath)'. Run 'frank-cli extract --project $(MSBuildProjectFullPath)' then 'frank-cli compile' to generate runtime state." />
  </Target>
</Project>
