<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net8.0;net9.0;net10.0</TargetFrameworks>
    <PackageTags>semantic;vocabulary;linked-data;rdf</PackageTags>
    <Description>Vocabulary CE and registry types for Frank semantic discovery</Description>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="ProvOClass.fs" />
    <Compile Include="VocabularyRegistry.fs" />
    <Compile Include="VocabularyBuilder.fs" />
    <Compile Include="Mapping.fs" />
    <Compile Include="LockFile.fs" />
    <Compile Include="ResolvedModel.fs" />
    <Compile Include="OntologyTypes.fs" />
    <Compile Include="ConventionEngine.fs" />
    <Compile Include="VocabFetcher.fs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="dotNetRdf.Core" Version="3.5.1" />
  </ItemGroup>

</Project>
