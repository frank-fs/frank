<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
    <!-- Firewall: this project has NO ProjectReference to the app. The naive
         client speaks only HTTP, proving discovery works for any client. -->
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="ServerFixture.fs" />
    <Compile Include="GameplayTests.fs" />
    <Compile Include="SemanticTests.fs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.11.1" />
    <PackageReference Include="Microsoft.Playwright.NUnit" Version="1.49.0" />
    <PackageReference Include="NUnit" Version="4.2.2" />
    <PackageReference Include="NUnit3TestAdapter" Version="4.6.0" />
  </ItemGroup>

</Project>
