{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://frank-fsharp.dev/schemas/affordance-map/v1",
  "title": "Frank Affordance Map",
  "description": "Machine-readable mapping of (route, state) pairs to available HTTP actions and link relations. Generated by frank-cli, consumed by Frank.Affordances middleware.",
  "type": "object",
  "required": ["version", "baseUri", "entries"],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0",
      "description": "Schema version for forward compatibility"
    },
    "baseUri": {
      "type": "string",
      "format": "uri",
      "description": "Base URI for ALPS profile namespace"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "entries": {
      "type": "object",
      "description": "Map keyed by '{routeTemplate}|{stateKey}' composite keys",
      "additionalProperties": {
        "$ref": "#/$defs/AffordanceEntry"
      }
    }
  },
  "$defs": {
    "AffordanceEntry": {
      "type": "object",
      "required": ["allowedMethods", "linkRelations"],
      "properties": {
        "allowedMethods": {
          "type": "array",
          "items": { "type": "string" },
          "description": "HTTP methods available in this state (e.g., GET, POST)"
        },
        "linkRelations": {
          "type": "array",
          "items": { "$ref": "#/$defs/LinkRelation" }
        },
        "profileUrl": {
          "type": "string",
          "format": "uri",
          "description": "ALPS profile URL for this resource"
        }
      }
    },
    "LinkRelation": {
      "type": "object",
      "required": ["rel", "method"],
      "properties": {
        "rel": {
          "type": "string",
          "description": "IANA-registered or ALPS-derived link relation type URI"
        },
        "href": {
          "type": "string",
          "description": "Target URL template"
        },
        "method": {
          "type": "string",
          "description": "HTTP method for this transition"
        },
        "title": {
          "type": "string",
          "description": "Human-readable label"
        }
      }
    }
  }
}
