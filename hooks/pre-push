#!/bin/sh
# Pre-push hook:
#   1. Protect master/main from destructive pushes:
#      - block deletion
#      - block non-fast-forward unless the local tracking ref matches the
#        actual remote tip (equivalent to --force-with-lease succeeding)
#   2. Feature branches: no local restriction.
#   3. Run Entire CLI to push session logs alongside the user's push.
#
# Backed by .github/rulesets/master-protection.json (deletes, linear history,
# CI status). Server cannot distinguish --force from --force-with-lease, so
# the lease semantics are enforced here.
#
# Escape: prefix push with FRANK_ALLOW_DESTRUCTIVE_PUSH=1.

remote_name=$1
zero='0000000000000000000000000000000000000000'
allow="${FRANK_ALLOW_DESTRUCTIVE_PUSH:-0}"

while read local_ref local_sha remote_ref remote_sha; do
    [ -z "$local_ref" ] && continue

    case "$remote_ref" in
        refs/heads/master|refs/heads/main) ;;
        *) continue ;;  # feature branch: no local restriction
    esac

    reason=""

    if [ "$local_sha" = "$zero" ]; then
        reason="branch delete: $remote_ref"
    elif [ "$remote_sha" != "$zero" ]; then
        if ! git merge-base --is-ancestor "$remote_sha" "$local_sha" 2>/dev/null; then
            # Non-fast-forward. Apply --force-with-lease semantics:
            # only allow if our local tracking ref matches the actual remote tip.
            tracking_ref="refs/remotes/$remote_name/${remote_ref#refs/heads/}"
            tracking_sha=$(git rev-parse --verify "$tracking_ref" 2>/dev/null || echo "")
            if [ "$tracking_sha" = "$remote_sha" ]; then
                continue  # safe rewrite: caller has the current tip
            fi
            reason="non-fast-forward and local tracking ref is stale: $remote_ref (run \`git fetch\` first, then --force-with-lease)"
        fi
    fi

    if [ -n "$reason" ] && [ "$allow" != "1" ]; then
        cat >&2 <<EOF

================================================================
  BLOCKED: destructive push to $remote_name — $reason

  master/main is protected. To bypass with explicit user approval:
    FRANK_ALLOW_DESTRUCTIVE_PUSH=1 git push ...
================================================================
EOF
        exit 1
    fi
done

# Existing Entire CLI integration.
entire hooks git pre-push "$remote_name" || true
exit 0
