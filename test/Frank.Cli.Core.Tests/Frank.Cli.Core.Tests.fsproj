    <Compile Include="Analysis/ProjectLoaderTests.fs" />
    <Compile Include="TypeMapperTests.fs" />
    <Compile Include="RouteMapperTests.fs" />
    <Compile Include="CapabilityMapperTests.fs" />
    <Compile Include="ShapeGeneratorTests.fs" />
    <Compile Include="VocabularyAlignerTests.fs" />
    <Compile Include="Statechart/FormatDetectorTests.fs" />
    <Compile Include="Statechart/FormatPipelineTests.fs" />
    <Compile Include="Statechart/ValidationReportFormatterTests.fs" />
    <Compile Include="Statechart/StatechartDocumentJsonTests.fs" />
    <Compile Include="Commands/ExtractCommandTests.fs" />
    <Compile Include="Commands/ClarifyCommandTests.fs" />
    <Compile Include="Commands/ValidateCommandTests.fs" />
    <Compile Include="Commands/DiffCommandTests.fs" />
    <Compile Include="Commands/CompileCommandTests.fs" />
    <Compile Include="Output/JsonOutputTests.fs" />
    <Compile Include="Output/TextOutputTests.fs" />
    <Compile Include="Unified/UnifiedModelTests.fs" />
    <Compile Include="Unified/UnifiedCacheTests.fs" />
    <Compile Include="Unified/OpenApiConsistencyValidatorTests.fs" />
    <Compile Include="Unified/UnifiedExtractorTests.fs" />
    <Compile Include="Unified/UnifiedAlpsGeneratorTests.fs" />
    <Compile Include="Unified/AffordanceMapGeneratorTests.fs" />
    <Compile Include="Unified/ExtractionStateProjectorTests.fs" />
