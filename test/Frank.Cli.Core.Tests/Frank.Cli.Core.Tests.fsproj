<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <IsTestProject>true</IsTestProject>
    <GenerateProgramFile>false</GenerateProgramFile>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="ExtractorTests.fs" />
    <Compile Include="VocabularyEvaluatorTests.fs" />
    <Compile Include="PipelineTests.fs" />
    <Compile Include="DiscoveryEmitterTests.fs" />
    <Compile Include="LinkedDataEmitterTests.fs" />
    <Compile Include="SemanticModelEmitterTests.fs" />
    <Compile Include="TypeIdentityTests.fs" />
    <Compile Include="Program.fs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.14.1" />
    <PackageReference Include="Expecto" Version="10.2.3" />
    <PackageReference Include="Expecto.FsCheck" Version="10.2.3" />
    <PackageReference Include="YoloDev.Expecto.TestSdk" Version="0.14.3" />
    <PackageReference Include="FSharp.Compiler.Service" Version="43.10.103" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../../src/Frank.Cli.Core/Frank.Cli.Core.fsproj" />
  </ItemGroup>

</Project>
