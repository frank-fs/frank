    <Compile Include="fixtures/DuplicatePost.fs" />
    <Compile Include="fixtures/DuplicatePut.fs" />
    <Compile Include="fixtures/DuplicateDelete.fs" />
    <Compile Include="fixtures/DuplicatePatch.fs" />
    <Compile Include="fixtures/DuplicateHead.fs" />
    <Compile Include="fixtures/DuplicateOptions.fs" />
    <Compile Include="fixtures/DuplicateConnect.fs" />
    <Compile Include="fixtures/DuplicateTrace.fs" />
    <Compile Include="fixtures/AllMethodsOnce.fs" />
    <Compile Include="fixtures/DatastarConflict.fs" />
    <Compile Include="fixtures/DatastarWithPost.fs" />
    <Compile Include="fixtures/DatastarNoConflict.fs" />
    <Compile Include="AnalyzerTests.fs" />
