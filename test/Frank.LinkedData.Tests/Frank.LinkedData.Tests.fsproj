<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
    <GenerateProgramFile>false</GenerateProgramFile>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="GraphLoaderTests.fs" />
    <Compile Include="LinkedDataConfigTests.fs" />
    <Compile Include="InstanceProjectorTests.fs" />
    <Compile Include="FormatterTests.fs" />
    <Compile Include="ContentNegotiationTests.fs" />
    <Compile Include="StartupValidationTests.fs" />
    <Compile Include="Program.fs" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="TestData/manifest.json" LogicalName="Frank.Semantic.manifest.json" />
    <EmbeddedResource Include="TestData/ontology.owl.xml" LogicalName="Frank.Semantic.ontology.owl.xml" />
    <EmbeddedResource Include="TestData/shapes.shacl.ttl" LogicalName="Frank.Semantic.shapes.shacl.ttl" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.14.1" />
    <PackageReference Include="Expecto" Version="10.2.3" />
    <PackageReference Include="YoloDev.Expecto.TestSdk" Version="0.14.3" />
    <PackageReference Include="Microsoft.AspNetCore.TestHost" Version="10.0.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../../src/Frank.LinkedData/Frank.LinkedData.fsproj" />
  </ItemGroup>

</Project>
