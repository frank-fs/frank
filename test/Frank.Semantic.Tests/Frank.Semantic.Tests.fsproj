<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <IsTestProject>true</IsTestProject>
    <GenerateProgramFile>false</GenerateProgramFile>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="VocabularyRegistryTests.fs" />
    <Compile Include="VocabFetcherTests.fs" />
    <Compile Include="ConventionEngineTests.fs" />
    <Compile Include="LockFileTests.fs" />
    <Compile Include="ResolvedModelTests.fs" />
    <Compile Include="OntologyTypesTests.fs" />
    <Compile Include="Program.fs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.14.1" />
    <PackageReference Include="Expecto" Version="10.2.3" />
    <PackageReference Include="Expecto.FsCheck" Version="10.2.3" />
    <PackageReference Include="YoloDev.Expecto.TestSdk" Version="0.14.3" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../../src/Frank.Semantic/Frank.Semantic.fsproj" />
  </ItemGroup>

</Project>
